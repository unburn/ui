{
  "name": "@unburn/ui",
  "version": "1.4.0",
  "private": false,
  "description": "A premium, softly-rounded React component library.",
  "author": "Unburn",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/ui.css",
    "./Accordion": {
      "types": "./dist/components/Accordion/Accordion.d.ts",
      "import": "./dist/components/Accordion/Accordion.mjs",
      "require": "./dist/components/Accordion/Accordion.cjs"
    },
    "./Alert": {
      "types": "./dist/components/Alert/Alert.d.ts",
      "import": "./dist/components/Alert/Alert.mjs",
      "require": "./dist/components/Alert/Alert.cjs"
    },
    "./Avatar": {
      "types": "./dist/components/Avatar/Avatar.d.ts",
      "import": "./dist/components/Avatar/Avatar.mjs",
      "require": "./dist/components/Avatar/Avatar.cjs"
    },
    "./Badge": {
      "types": "./dist/components/Badge/Badge.d.ts",
      "import": "./dist/components/Badge/Badge.mjs",
      "require": "./dist/components/Badge/Badge.cjs"
    },
    "./Button": {
      "types": "./dist/components/Button/Button.d.ts",
      "import": "./dist/components/Button/Button.mjs",
      "require": "./dist/components/Button/Button.cjs"
    },
    "./Checkbox": {
      "types": "./dist/components/Checkbox/Checkbox.d.ts",
      "import": "./dist/components/Checkbox/Checkbox.mjs",
      "require": "./dist/components/Checkbox/Checkbox.cjs"
    },
    "./CodeBlock": {
      "types": "./dist/components/CodeBlock/CodeBlock.d.ts",
      "import": "./dist/components/CodeBlock/CodeBlock.mjs",
      "require": "./dist/components/CodeBlock/CodeBlock.cjs"
    },
    "./Dock": {
      "types": "./dist/components/Dock/Dock.d.ts",
      "import": "./dist/components/Dock/Dock.mjs",
      "require": "./dist/components/Dock/Dock.cjs"
    },
    "./Dropzone": {
      "types": "./dist/components/Dropzone/Dropzone.d.ts",
      "import": "./dist/components/Dropzone/Dropzone.mjs",
      "require": "./dist/components/Dropzone/Dropzone.cjs"
    },
    "./Input": {
      "types": "./dist/components/Input/Input.d.ts",
      "import": "./dist/components/Input/Input.mjs",
      "require": "./dist/components/Input/Input.cjs"
    },
    "./Select": {
      "types": "./dist/components/Select/Select.d.ts",
      "import": "./dist/components/Select/Select.mjs",
      "require": "./dist/components/Select/Select.cjs"
    },
    "./Switch": {
      "types": "./dist/components/Switch/Switch.d.ts",
      "import": "./dist/components/Switch/Switch.mjs",
      "require": "./dist/components/Switch/Switch.cjs"
    },
    "./Slider": {
      "types": "./dist/components/Slider/Slider.d.ts",
      "import": "./dist/components/Slider/Slider.mjs",
      "require": "./dist/components/Slider/Slider.cjs"
    },
    "./Tooltip": {
      "types": "./dist/components/Tooltip/Tooltip.d.ts",
      "import": "./dist/components/Tooltip/Tooltip.mjs",
      "require": "./dist/components/Tooltip/Tooltip.cjs"
    },
    "./Textarea": {
      "types": "./dist/components/Textarea/Textarea.d.ts",
      "import": "./dist/components/Textarea/Textarea.mjs",
      "require": "./dist/components/Textarea/Textarea.cjs"
    },
    "./VideoEmbed": {
      "types": "./dist/components/VideoEmbed/VideoEmbed.d.ts",
      "import": "./dist/components/VideoEmbed/VideoEmbed.mjs",
      "require": "./dist/components/VideoEmbed/VideoEmbed.cjs"
    },
    "./utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.mjs",
      "require": "./dist/lib/utils.cjs"
    },
    "./colors": {
      "types": "./dist/lib/colors.d.ts",
      "import": "./dist/lib/colors.mjs",
      "require": "./dist/lib/colors.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "glassmorphism",
    "soft-ui",
    "typescript",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/unburn/ui"
  },
  "homepage": "https://ui.unburn.tech",
  "bugs": {
    "url": "https://github.com/unburn/ui/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib",
    "build:docs": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --outDir dist-docs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-live": "^4.1.8",
    "react-router-dom": "^7.15.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0"
  }
}